  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "setup": "node scripts/setup-keys.js",
    "build": "npx --yes electron-builder@latest --win --x64",
    "pack": "npx --yes electron-builder@latest --dir",
